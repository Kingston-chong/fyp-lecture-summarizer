# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
/scripts
/testpack

# production
/build

# misc
.DS_Store
*.pem

# local IDE and AI tooling
.cursor/
.claude/
.qodo/
.vscode/

# local dev binaries and dumps
BUILD/

# archives and scratch files (prevent re-committing backups)
*.zip
tmp_*.txt

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma

.env*.local
settings.local.json