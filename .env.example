# Copy to .env.local (or .env) and fill in values. Do not commit secrets.

# ── Required ──────────────────────────────────────────────────────────────────
DATABASE_URL="mysql://root:@localhost:3306/slide2notes_db"
NEXTAUTH_SECRET="replace-with-long-random-secret"
# Vercel Blob — file uploads (local dev + production). Create at vercel.com → Storage → Blob
BLOB_READ_WRITE_TOKEN=""

# ── App URL (emails, auth links) ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# NEXTAUTH_URL="http://localhost:3000"

# ── LLM (set at least one direct key, OR OpenRouter to proxy all models) ─────
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"
DEEPSEEK_API_KEY=""
# OPENROUTER_API_KEY=""
# OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
# OPENROUTER_HTTP_REFERER=""
# OPENROUTER_APP_NAME=""
# OPENROUTER_GEMINI_MODEL=""

# ── Google sign-in (optional) ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Email / forgot-password (optional) ────────────────────────────────────────
EMAIL_USER=""
EMAIL_PASS=""

# ── Slide generation (use Alai and/or 2slides — only the provider you pick) ──
ALAI_API_KEY=""
# ALAI_API_KEY_FALLBACK="backup_key_1,backup_key_2"
# ALAI_API_KEY_2=""
TWOSLIDES_API_KEY=""

# ── Web search & academic references (optional) ───────────────────────────────
TAVILY_API_KEY=""
OPENALEX_API_KEY=""
SEMANTIC_SCHOLAR_API_KEY=""

# ── Admin (optional) ──────────────────────────────────────────────────────────
ADMIN_EMAIL="admin@example.com"
DOCUMENT_VIEW_TOKEN_SECRET=""

# ── PPTX → PDF on serverless (optional; local dev can use LibreOffice instead)
# GOTENBERG_URL="http://localhost:3001"

# ── Rate limiting across instances (optional; defaults to in-memory) ──────────
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# ── Tuning (optional — defaults exist in code) ────────────────────────────────
# SUMMARY_MAX_INPUT_CHARS="12000"
# SUMMARY_EXTRACT_CONCURRENCY="2"
# CHAT_MAX_TOKENS="4096"
# CHAT_MAX_CONTEXT_CHARS="24000"
# CHAT_MAX_ATTACHMENT_CONTEXT_CHARS="12000"
# CHAT_MAX_IMAGE_BYTES="3500000"
# CHAT_WEB_SEARCH="1"
# CHAT_WEB_SNIPPET_MAX_CHARS="6000"
# WEBPAGE_EXTRACT_MAX_CHARS="80000"
# TAVILY_MAX_RESULTS="8"
# TAVILY_SEARCH_DEPTH="basic"
# TAVILY_SOURCES_MAX_RESULTS="10"
# TAVILY_SOURCES_SEARCH_DEPTH="advanced"
# ACADEMIC_SEARCH_LLM_QUERIES="1"
# ACADEMIC_SEARCH_LLM_CHARS="14000"
# SLIDES_MAX_USER_PROMPT_CHARS="4000"
