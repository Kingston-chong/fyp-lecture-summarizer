# Core app
DATABASE_URL="mysql://user:password@localhost:3306/lecture_summarizer"
NEXTAUTH_SECRET="replace-with-long-random-secret"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
DOCUMENT_VIEW_TOKEN_SECRET="optional-override-for-doc-view-tokens"
ADMIN_EMAIL="admin@example.com"

# Google auth + CSE
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_API_KEY=""
GOOGLE_CSE_ID=""

# Optional email (forgot-password flow)
EMAIL_USER=""
EMAIL_PASS=""

# LLM providers
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"
DEEPSEEK_API_KEY=""
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
OPENROUTER_API_KEY=""
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_HTTP_REFERER=""
OPENROUTER_APP_NAME=""
OPENROUTER_GEMINI_MODEL=""

# Search / enrichment providers
# Lecturer summarize: LLM reads lecture text and builds academic search queries (set to 0 to use word-frequency only)
# ACADEMIC_SEARCH_LLM_QUERIES="1"
# ACADEMIC_SEARCH_LLM_CHARS="14000"
# Optional but recommended — avoids Semantic Scholar rate limits (429) in chat references
SEMANTIC_SCHOLAR_API_KEY=""
# Free at https://openalex.org/settings/api — required for reliable OpenAlex search (mailto= is deprecated)
OPENALEX_API_KEY=""
TAVILY_API_KEY=""
TAVILY_MAX_RESULTS="5"
TAVILY_SEARCH_DEPTH="basic"
CHAT_WEB_SEARCH="1"
CHAT_WEB_SNIPPET_MAX_CHARS="6000"
UNSPLASH_ACCESS_KEY=""
TWOSLIDES_API_KEY=""

# Slide generation
ALAI_API_KEY=""
SLIDES_MAX_USER_PROMPT_CHARS="4000"
# Optional: Gotenberg URL for server-side PPTX→PDF and Improve-PPT OCR on PPTX (required on Vercel for PPTX OCR)
# GOTENBERG_URL=""

# Summarization and chat limits
SUMMARY_MAX_INPUT_CHARS="12000"
SUMMARY_EXTRACT_CONCURRENCY="2"
CHAT_MAX_TOKENS="4096"
CHAT_MAX_CONTEXT_CHARS="24000"
CHAT_MAX_ATTACHMENT_CONTEXT_CHARS="12000"
CHAT_MAX_IMAGE_BYTES="3500000"

# Rate limiting (optional persistent backend)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
