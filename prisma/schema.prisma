generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  Student
  Lecturer
  RatherNotSay @map("Rather not say")
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  username     String   @unique
  passwordHash String
  role         UserRole @default(Student)
  createdAt    DateTime @default(now())
  documents    Document[]
  summaries    Summary[]
  chatThreads  ChatThread[]
  chatShares   ChatShare[]
  highlights   SummaryHighlight[]
  quizSets      QuizSet[]
  quizAttempts  QuizAttempt[]
  slideDecks    SlideDeck[]
  flashcardSets FlashcardSet[]
}

model PasswordReset {
  id          Int       @id @default(autoincrement())
  email       String    @unique
  otp         String
  expiresAt   DateTime
  used        Boolean   @default(false)
  token       String?
  tokenExpiry DateTime?
  createdAt   DateTime  @default(now())
}

model Document {
  id        Int      @id @default(autoincrement())
  userId    Int
  name      String
  url       String   // Vercel Blob URL
  type      String   // PDF, PPTX etc.
  size      Int      // bytes
  sourceUrl String?  @db.VarChar(2048) // original webpage when imported from web
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  summaries SummaryDocument[]
}

model Summary {
  id          Int      @id @default(autoincrement())
  userId      Int
  title       String   // auto-generated from first doc name
  model       String   // chatgpt / deepseek / gemini
  summarizeFor String  // lecturer / student
  prompt      String?  // additional prompt
  publishedYearFrom Int? // lecturer reference search (inclusive)
  publishedYearTo   Int? // lecturer reference search (inclusive)
  output      String   @db.LongText
  pinned      Boolean  @default(false)
  pinnedAt    DateTime?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  documents   SummaryDocument[]
  references  SummaryReference[]
  highlights  SummaryHighlight[]
  chatThreads ChatThread[]
  chatShare   ChatShare?
  quizSets       QuizSet[]
  slideDecks     SlideDeck[]
  flashcardSets  FlashcardSet[]
}

model SummaryReference {
  id         Int      @id @default(autoincrement())
  summaryId  Int
  marker     Int
  kind       String   @db.VarChar(16)
  title      String   @db.VarChar(512)
  authors    String?  @db.VarChar(512)
  year       Int?
  venue      String?  @db.VarChar(256)
  doi        String?  @db.VarChar(128)
  url        String?  @db.VarChar(2048)
  abstract   String?  @db.Text
  provider   String?  @db.VarChar(32)
  externalId String?  @db.VarChar(128)
  anchorIds  Json?
  createdAt  DateTime @default(now())

  summary Summary @relation(fields: [summaryId], references: [id], onDelete: Cascade)

  @@unique([summaryId, marker])
  @@index([summaryId])
}

model SummaryHighlight {
  id        Int      @id @default(autoincrement())
  userId    Int
  summaryId Int
  context   String   @default("summary") @db.VarChar(16) // summary | chat
  messageId Int?
  quote     String   @db.VarChar(2000)
  color     String   @default("#fef08a") @db.VarChar(16)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  summary   Summary  @relation(fields: [summaryId], references: [id], onDelete: Cascade)
  message   ChatMessage? @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([summaryId])
  @@index([messageId])
}

// Stores persistent chat turns for the "summary -> continue conversation" view.
// We keep a single thread per (userId, summaryId) so refresh/resume continues the conversation.
model ChatThread {
  id        Int      @id @default(autoincrement())
  userId    Int
  summaryId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages ChatMessage[]

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  summary Summary @relation(fields: [summaryId], references: [id], onDelete: Cascade)

  @@unique([userId, summaryId])
  @@index([summaryId])
}

model ChatMessage {
  id         Int      @id @default(autoincrement())
  threadId   Int
  turn       Int
  role       String   @db.VarChar(16) // "user" | "assistant"
  content    String   @db.LongText
  modelLabel String?  @db.VarChar(32) // e.g. "ChatGPT" / "DeepSeek" / "Gemini" (assistant only)
  createdAt  DateTime @default(now())

  thread     ChatThread         @relation(fields: [threadId], references: [id], onDelete: Cascade)
  highlights SummaryHighlight[]

  @@index([threadId])
  @@unique([threadId, turn])
}

// Public read-only snapshot of summary + chat (ChatGPT-style share link).
model ChatShare {
  id         Int      @id @default(autoincrement())
  userId     Int
  summaryId  Int      @unique
  shareToken String   @unique @db.VarChar(64)
  published  Boolean  @default(false)
  snapshot   Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  summary Summary @relation(fields: [summaryId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Links summaries to which documents were used
model SummaryDocument {
  summaryId  Int
  documentId Int
  summary    Summary  @relation(fields: [summaryId], references: [id])
  document   Document @relation(fields: [documentId], references: [id])
  @@id([summaryId, documentId])
}

model QuizSet {
  id          Int            @id @default(autoincrement())
  userId      Int
  summaryId   Int
  title       String
  settings    Json?          // Store generation settings (difficulty, types, etc.)
  published           Boolean        @default(false)
  acceptingResponses  Boolean        @default(false)
  closesAt            DateTime?
  shareToken          String?        @unique @db.VarChar(64)
  createdAt   DateTime       @default(now())
  questions   QuizQuestion[]
  attempts    QuizAttempt[]
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  summary     Summary        @relation(fields: [summaryId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([summaryId])
}

model QuizAttempt {
  id              Int      @id @default(autoincrement())
  userId          Int?
  quizSetId       Int
  respondentLabel String?  @db.VarChar(120)
  score           Int
  totalQuestions  Int
  answers         Json?
  createdAt       DateTime @default(now())

  user    User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizSet QuizSet @relation(fields: [quizSetId], references: [id], onDelete: Cascade)

  @@index([quizSetId])
  @@index([userId, quizSetId])
}

model QuizQuestion {
  id          Int      @id @default(autoincrement())
  quizSetId   Int
  question    String   @db.Text
  type        String   // MCQ, True/False, FillInBlanks, ShortAnswer, Match
  options     Json?    // For MCQ, Match (Array or Object)
  answer      String   @db.Text
  explanation String?  @db.Text
  order       Int      @default(0)
  
  quizSet     QuizSet  @relation(fields: [quizSetId], references: [id], onDelete: Cascade)

  @@index([quizSetId])
}

// Alai-generated slide decks saved for a summary (PPTX on Vercel Blob for long-term access).
model SlideDeck {
  id               Int      @id @default(autoincrement())
  userId           Int
  summaryId        Int
  title            String   @db.VarChar(512)
  alaiGenerationId String   @db.VarChar(128)
  provider         String?  @db.VarChar(32)   // "alai" | "2slides"
  providerDeckId   String?  @db.VarChar(256)
  /** Vercel Blob pathname (or legacy URL) — use server get() with private access, not public HTTP */
  pptxUrl          String   @db.VarChar(2048)
  /** Optional archived PDF blob pathname */
  pdfUrl           String?  @db.VarChar(2048)
  createdAt        DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  summary Summary @relation(fields: [summaryId], references: [id], onDelete: Cascade)

  @@index([summaryId])
  @@index([userId])
}

model FlashcardSet {
  id        Int         @id @default(autoincrement())
  userId    Int
  summaryId Int
  title     String
  settings  Json?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  summary Summary     @relation(fields: [summaryId], references: [id], onDelete: Cascade)
  cards   Flashcard[]

  @@index([userId])
  @@index([summaryId])
}

model Flashcard {
  id             Int          @id @default(autoincrement())
  flashcardSetId Int
  front          String       @db.Text
  back           String       @db.Text
  order          Int          @default(0)
  /// "known" | "learning" — last study choice for this card
  studyStatus    String?

  set FlashcardSet @relation(fields: [flashcardSetId], references: [id], onDelete: Cascade)

  @@index([flashcardSetId])
}